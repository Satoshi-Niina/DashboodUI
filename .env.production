# 実行環境
NODE_ENV=production

# Cloud SQL接続設定 (Cloud Runからの接続)
# Cloud SQL インスタンス接続名 (例: project-id:region:instance-name)
CLOUD_SQL_INSTANCE=your-project:region:instance-name

# データベース接続情報 (GCP PostgreSQL)
# ユーザー名、パスワード、データベース名を正しく設定してください
DB_NAME=webappdb
DB_USER=postgres
DB_PASSWORD=Takabeni

# フォールバック用の接続文字列（環境変数が個別に設定されない場合）
# DATABASE_URL=postgresql://postgres:Takabeni@/webappdb?host=/cloudsql/your-project:region:instance-name

# サーバーポート (Cloud Runが自動的にPORT=8080を設定するため、ここでは指定不要)
# PORT環境変数はCloud Runが管理します

# JWT秘密鍵 (強力なランダム文字列を設定してください)
JWT_SECRET=I713ZkufHbpsKO81UnrwwrEhd5lyalvA5T36vuUcilNzuWhhCerkXr4EkzBSKNRU0

# CORS許可オリジン (一般公開の場合は * または特定のドメインをカンマ区切りで指定)
# 例: https://yourdomain.com,https://emergency.example.com
CORS_ORIGIN=*

# 各アプリケーションのURL設定 (本番環境のエンドポイント)
APP_URL_EMERGENCY=https://emergency-client-800711608362.asia-northeast2.run.app
APP_URL_PLANNING=https://railway-client-800711608362.asia-northeast2.run.app
APP_URL_PLANNING_API=https://operation-management-server-800711608362.asia-northeast2.run.app
APP_URL_EQUIPMENT=https://operation-management-client-800711608362.asia-northeast2.run.app
APP_URL_FAILURE=https://machine-failure-client-800711608362.asia-northeast2.run.app

# ダッシュボード起動リンク用（推奨）
URL_PLANNING=https://railway-client-800711608362.asia-northeast2.run.app
URL_EQUIPMENT=https://operation-management-client-800711608362.asia-northeast2.run.app
URL_EMERGENCY=https://emergency-client-800711608362.asia-northeast2.run.app
URL_FAILURE=https://machine-failure-client-800711608362.asia-northeast2.run.app

# 起動URL環境変数（推奨: ダッシュボード起動リンク）
OPERATION_MANAGEMENT_CLIENT_URL=https://operation-management-client-800711608362.asia-northeast2.run.app
OPERATION_MANAGEMENT_SERVER_URL=https://operation-management-server-800711608362.asia-northeast2.run.app
EMERGENCY_APP_URL=https://emergency-client-800711608362.asia-northeast2.run.app
EQUIPMENT_APP_URL=https://operation-management-client-800711608362.asia-northeast2.run.app
